<script>
    // ════════════════════════════════════════
    // CONFIG — set blog ID from server/template
    // ════════════════════════════════════════
    // In a real app, inject this from your backend:
    // e.g. const BLOG_ID = "{{ blog.id }}";
    const BLOG_ID = window.__BLOG_ID__ || getUrlParam('id') || '123';

    function getUrlParam(name) {
        return new URLSearchParams(window.location.search).get(name);
    }

    // ════════════════════════════════════════
    // CHANGED TRACKER
    // ════════════════════════════════════════
    function cbMarkChanged(indicatorId) {
        const el = document.getElementById(indicatorId);
        if (el) el.style.display = 'inline';
    }

    // ════════════════════════════════════════
    // IMAGE PICKER UTILITIES
    // ════════════════════════════════════════
    function cbFormatBytes(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / 1048576).toFixed(1) + ' MB';
    }

    function cbHandleFileSelect(input, previewId) {
        const file = input.files[0];
        if (!file) return;
        if (file.size > 5 * 1024 * 1024) { cbToast('Image must be under 5MB', 'error'); input.value = ''; return; }
        const preview = document.getElementById(previewId);
        const img = preview.querySelector('img');
        const reader = new FileReader();
        reader.onload = e => {
            img.src = e.target.result;
            preview.classList.add('show');
            const nameEl = document.getElementById(previewId.replace('-preview', '-name'));
            const sizeEl = document.getElementById(previewId.replace('-preview', '-size'));
            if (nameEl) nameEl.textContent = file.name;
            if (sizeEl) sizeEl.textContent = cbFormatBytes(file.size);
            cbMarkChanged('cb-basic-changed');
        };
        reader.readAsDataURL(file);
    }

    function cbDragOver(e, zoneId) { e.preventDefault(); document.getElementById(zoneId).classList.add('drag-over'); }
    function cbDragLeave(zoneId) { document.getElementById(zoneId).classList.remove('drag-over'); }
    function cbDrop(e, inputId, previewId, zoneId) {
        e.preventDefault();
        document.getElementById(zoneId).classList.remove('drag-over');
        const file = e.dataTransfer.files[0];
        if (!file || !file.type.startsWith('image/')) { cbToast('Please drop an image file', 'error'); return; }
        const input = document.getElementById(inputId);
        const dt = new DataTransfer();
        dt.items.add(file);
        input.files = dt.files;
        cbHandleFileSelect(input, previewId);
    }

    // ── Hero replace toggle ──
    function cbShowHeroReplace() {
        document.getElementById('hero-current').style.display = 'none';
        document.getElementById('hero-replace-area').style.display = 'block';
    }
    function cbCancelHeroReplace() {
        document.getElementById('hero-input').value = '';
        document.getElementById('hero-preview').classList.remove('show');
        document.getElementById('hero-preview').querySelector('img').src = '';
        document.getElementById('hero-replace-area').style.display = 'none';
        document.getElementById('hero-current').style.display = 'block';
    }

    // ════════════════════════════════════════
    // TAG SYSTEM
    // ════════════════════════════════════════
    (function () {
        window._cbAllTags = [];
        window._cbSelectedTags = [];
        window._cbTagIdCounter = 9000;
        window._cbDropdownOpen = false;
        window._cbTagTimer = null;

        window.cbOpenTagDropdown = function () {
            window._cbDropdownOpen = true;
            document.getElementById('cb-tag-dropdown').classList.add('is-open');
            document.getElementById('cb-tag-display').classList.add('is-open');
            document.getElementById('cb-tag-search').focus();
            cbRenderTagOptions('');
        };
        window.cbHandleTagSearch = function (val) {
            clearTimeout(window._cbTagTimer);
            window._cbTagTimer = setTimeout(() => cbSearchTags(val), 320);
        };
        function cbSearchTags(query) {
            const dd = document.getElementById('cb-tag-dropdown');
            dd.innerHTML = '<div class="cb-tag-loading"><span class="cb-spinner"></span>Searching…</div>';
            setTimeout(() => {
                const q = query.toLowerCase().trim();
                const results = window._cbAllTags.filter(t => t.name.toLowerCase().includes(q));
                cbRenderTagOptions(query, results);
            }, 280);
        }
        window.cbRenderTagOptions = function (query, results) {
            if (results === undefined) {
                const q = query.toLowerCase().trim();
                results = window._cbAllTags.filter(t => t.name.toLowerCase().includes(q));
            }
            const dd = document.getElementById('cb-tag-dropdown');
            const q = query.trim();
            let html = '';
            results.forEach(tag => {
                const sel = window._cbSelectedTags.some(s => s.id === tag.id);
                html += `<div class="cb-tag-opt ${sel ? 'is-sel' : ''}" onclick="cbToggleTag(${tag.id}, '${tag.name.replace(/'/g, "\\'")}')">  ${tag.name}</div>`;
            });
            const exact = window._cbAllTags.some(t => t.name.toLowerCase() === q.toLowerCase());
            if (q && !exact) html += `<div class="cb-tag-opt create-opt" onclick="cbCreateTag('${q.replace(/'/g, "\\'")}')">Create "<strong>${q}</strong>"</div>`;
            if (!html) {
                html = `<div class="cb-tag-loading" style="color:var(--muted)">No tags found.</div>`;
                if (q) html += `<div class="cb-tag-opt create-opt" onclick="cbCreateTag('${q.replace(/'/g, "\\'")}')">Create "<strong>${q}</strong>"</div>`;
            }
            dd.innerHTML = html;
        };
        window.cbToggleTag = function (id, name) {
            const idx = window._cbSelectedTags.findIndex(t => t.id === id);
            if (idx >= 0) window._cbSelectedTags.splice(idx, 1);
            else window._cbSelectedTags.push({ id, name });
            cbRenderChips();
            cbRenderTagOptions(document.getElementById('cb-tag-search').value);
            cbMarkChanged('cb-basic-changed');
        };
        window.cbCreateTag = function (name) {
            const formatted = name.charAt(0).toUpperCase() + name.slice(1);
            const newTag = { id: ++window._cbTagIdCounter, name: formatted };
            window._cbAllTags.push(newTag);
            window._cbSelectedTags.push(newTag);
            document.getElementById('cb-tag-search').value = '';
            cbRenderChips();
            cbRenderTagOptions('');
            cbMarkChanged('cb-basic-changed');
        };
        window.cbRemoveTag = function (id) {
            window._cbSelectedTags = window._cbSelectedTags.filter(t => t.id !== id);
            cbRenderChips();
            if (window._cbDropdownOpen) cbRenderTagOptions(document.getElementById('cb-tag-search').value);
            cbMarkChanged('cb-basic-changed');
        };
        function cbRenderChips() {
            const display = document.getElementById('cb-tag-display');
            const input = document.getElementById('cb-tag-search');
            display.querySelectorAll('.cb-tag-chip').forEach(c => c.remove());
            window._cbSelectedTags.forEach(tag => {
                const chip = document.createElement('div');
                chip.className = 'cb-tag-chip';
                chip.innerHTML = `${tag.name} <span class="rm" onclick="event.stopPropagation();cbRemoveTag(${tag.id})">×</span>`;
                display.insertBefore(chip, input);
            });
        }
        window.cbHandleTagKeydown = function (e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                const q = e.target.value.trim();
                if (!q) return;
                const existing = window._cbAllTags.find(t => t.name.toLowerCase() === q.toLowerCase());
                if (existing) cbToggleTag(existing.id, existing.name);
                else cbCreateTag(q);
                e.target.value = '';
            }
            if (e.key === 'Escape') cbCloseTagDropdown();
        };
        window.cbCloseTagDropdown = function () {
            window._cbDropdownOpen = false;
            document.getElementById('cb-tag-dropdown').classList.remove('is-open');
            document.getElementById('cb-tag-display').classList.remove('is-open');
        };
        document.addEventListener('click', function (e) {
            if (!document.getElementById('cb-tag-wrapper').contains(e.target)) cbCloseTagDropdown();
        });

        // Seed sample tags
        window._cbAllTags = [
            { id: 1, name: 'Technology' }, { id: 2, name: 'Design' }, { id: 3, name: 'Business' },
            { id: 4, name: 'Tutorial' }, { id: 5, name: 'Frontend' }, { id: 6, name: 'Backend' },
            { id: 7, name: 'AI' }, { id: 8, name: 'UX' }
        ];
    })();

    // ════════════════════════════════════════
    // SECTIONS (TEXT / IMAGE)
    // ════════════════════════════════════════
    window._cbSectionFiles = {};     // { [domId]: File } — new file uploads
    window._cbSectionExisting = {};  // { [domId]: { url, public_id } } — existing image data
    window._cbSectionDbIds = {};     // { [domId]: number } — db record id (for updates)
    window._cbFeatureDbIds = {};     // { [domId]: number } — db record id (for updates)

    // 25002500 Guaranteed unique ID counters (never collide even in fast loops) 25002500
    window._cbUidSection = 0;
    window._cbUidFeature = 0;

    function cbAddSection(prefill) {
        const container = document.getElementById('cb-sections-container');
        document.getElementById('cb-sections-empty').style.display = 'none';
        const id = 'cbsec-' + (++window._cbUidSection);
        const num = container.querySelectorAll('.cb-section-item').length + 1;
        // Support both API shape (section_type) and manual shape (type)
        const type = (prefill && (prefill.section_type || prefill.type)) || 'TEXT';
        const textContent = (prefill && prefill.content) || '';
        const existingImageUrl = (prefill && prefill.image_url) || null;
        const existingPublicId = (prefill && prefill.image_public_id) || null;

        // Store db id if this is an existing record
        if (prefill && prefill.id) window._cbSectionDbIds[id] = prefill.id;
        if (existingImageUrl) window._cbSectionExisting[id] = { url: existingImageUrl, public_id: existingPublicId };

        const div = document.createElement('div');
        div.className = 'cb-section-item';
        div.id = id;
        div.innerHTML = `
        <div class="cb-section-head">
            <div class="cb-section-num">${num}</div>
            <div class="cb-select-wrap" style="flex:1;">
                <select class="cb-control" style="cursor:pointer;" onchange="cbToggleSectionType(this, '${id}')">
                    <option value="TEXT" ${type === 'TEXT' ? 'selected' : ''}>📝 Text</option>
                    <option value="IMAGE" ${type === 'IMAGE' ? 'selected' : ''}>🖼️ Image</option>
                </select>
            </div>
            <button type="button" class="cb-btn-delete" onclick="cbDeleteSection('${id}')">🗑 Delete</button>
        </div>

        <!-- TEXT FIELD -->
        <div class="cb-sec-text-field" id="${id}-text" style="display:${type === 'IMAGE' ? 'none' : 'block'}">
            <textarea class="cb-control" data-section-id="${id}" data-field="text"
                placeholder="Write your content here… HTML is supported." rows="4"
                oninput="cbMarkChanged('cb-basic-changed')">${textContent}</textarea>
        </div>

        <!-- IMAGE PICKER -->
        <div class="cb-image-picker ${type === 'IMAGE' ? 'active' : ''}" id="${id}-image">
            ${existingImageUrl ? `
            <!-- Existing image -->
            <div class="cb-section-existing" id="${id}-existing">
                <div class="cb-section-existing-info">
                    <img src="${existingImageUrl}" alt="Current section image" onerror="this.src='https://placehold.co/52x52/e4e7ef/7b82a0?text=IMG'">
                    <div class="cb-section-existing-text">
                        <span>Current image</span>
                        <strong>✓ Saved</strong>
                    </div>
                </div>
                <button type="button" class="cb-replace-btn" onclick="cbShowSectionReplace('${id}')">🔄 Replace</button>
            </div>
            ` : ''}

            <!-- Drop zone (hidden if existing, shown if new or replacing) -->
            <div id="${id}-new-area" style="display:${existingImageUrl ? 'none' : 'block'}">
                <div class="cb-drop-zone" id="${id}-dropzone"
                    ondragover="cbDragOver(event, '${id}-dropzone')"
                    ondragleave="cbDragLeave('${id}-dropzone')"
                    ondrop="cbDropSection(event, '${id}')">
                    <input type="file" id="${id}-file" accept="image/*" onchange="cbHandleSectionImage(this, '${id}')">
                    <div class="cb-drop-icon">📁</div>
                    <div class="cb-drop-text">
                        <strong>Click to upload</strong> or drag & drop<br>
                        PNG, JPG, WEBP — max 5MB
                    </div>
                </div>
                <div class="cb-img-preview" id="${id}-imgpreview">
                    <img src="" alt="Preview">
                    <div class="cb-img-preview-bar">
                        <span class="cb-img-name" id="${id}-imgname">—</span>
                        <span class="cb-img-size" id="${id}-imgsize">—</span>
                        <button type="button" class="cb-img-remove" onclick="cbRemoveSectionImage('${id}')">✕ Remove</button>
                    </div>
                </div>
                ${existingImageUrl ? `<div style="margin-top:8px;"><button type="button" class="cb-change-img-btn" onclick="cbCancelSectionReplace('${id}')">← Keep current</button></div>` : ''}
            </div>
        </div>
    `;
        container.appendChild(div);
        cbUpdateSectionCount();
    }

    function cbShowSectionReplace(id) {
        document.getElementById(`${id}-existing`).style.display = 'none';
        document.getElementById(`${id}-new-area`).style.display = 'block';
    }
    function cbCancelSectionReplace(id) {
        document.getElementById(`${id}-file`).value = '';
        const preview = document.getElementById(`${id}-imgpreview`);
        if (preview) { preview.classList.remove('show'); preview.querySelector('img').src = ''; }
        delete window._cbSectionFiles[id];
        document.getElementById(`${id}-new-area`).style.display = 'none';
        document.getElementById(`${id}-existing`).style.display = 'flex';
    }

    function cbToggleSectionType(select, id) {
        const isImage = select.value === 'IMAGE';
        document.getElementById(`${id}-text`).style.display = isImage ? 'none' : 'block';
        const imgPicker = document.getElementById(`${id}-image`);
        if (isImage) imgPicker.classList.add('active');
        else imgPicker.classList.remove('active');
        cbMarkChanged('cb-basic-changed');
    }
    function cbHandleSectionImage(input, id) {
        const file = input.files[0];
        if (!file) return;
        if (file.size > 5 * 1024 * 1024) { cbToast('Image must be under 5MB', 'error'); input.value = ''; return; }
        window._cbSectionFiles[id] = file;
        const reader = new FileReader();
        reader.onload = e => {
            const preview = document.getElementById(`${id}-imgpreview`);
            preview.querySelector('img').src = e.target.result;
            preview.classList.add('show');
            document.getElementById(`${id}-imgname`).textContent = file.name;
            document.getElementById(`${id}-imgsize`).textContent = cbFormatBytes(file.size);
            cbMarkChanged('cb-basic-changed');
        };
        reader.readAsDataURL(file);
    }
    function cbRemoveSectionImage(id) {
        document.getElementById(`${id}-file`).value = '';
        const preview = document.getElementById(`${id}-imgpreview`);
        preview.classList.remove('show');
        preview.querySelector('img').src = '';
        delete window._cbSectionFiles[id];
    }
    function cbDropSection(e, id) {
        e.preventDefault();
        document.getElementById(`${id}-dropzone`).classList.remove('drag-over');
        const file = e.dataTransfer.files[0];
        if (!file || !file.type.startsWith('image/')) { cbToast('Please drop an image file', 'error'); return; }
        const input = document.getElementById(`${id}-file`);
        const dt = new DataTransfer();
        dt.items.add(file);
        input.files = dt.files;
        cbHandleSectionImage(input, id);
    }
    function cbDeleteSection(id) {
        const el = document.getElementById(id);
        if (!el) return;
        el.style.animation = 'cbFadeOut 0.18s ease forwards';
        delete window._cbSectionFiles[id];
        delete window._cbSectionExisting[id];
        delete window._cbSectionDbIds[id];
        setTimeout(() => {
            el.remove();
            cbUpdateSectionCount();
            cbRenumberSections();
            if (!document.querySelector('.cb-section-item')) document.getElementById('cb-sections-empty').style.display = 'block';
        }, 180);
        cbMarkChanged('cb-basic-changed');
    }
    function cbUpdateSectionCount() {
        const n = document.querySelectorAll('.cb-section-item').length;
        document.getElementById('cb-sec-count').textContent = `${n} section${n !== 1 ? 's' : ''}`;
    }
    function cbRenumberSections() {
        document.querySelectorAll('.cb-section-item .cb-section-num').forEach((el, i) => el.textContent = i + 1);
    }

    // ════════════════════════════════════════
    // FEATURES
    // ════════════════════════════════════════
    function cbGetFeatureCount() { return document.querySelectorAll('.cb-feature-item').length; }
    function cbUpdateFeaturesUI() {
        const n = cbGetFeatureCount();
        const badge = document.getElementById('cb-feat-count');
        badge.textContent = `${n} / 3`;
        badge.className = 'cb-count-badge' + (n > 0 && n < 2 ? ' warn' : '');
        document.getElementById('cb-add-feat-btn').disabled = n >= 3;
        if (n === 0) document.getElementById('cb-features-empty').style.display = 'block';
    }
    function cbAddFeature(prefill) {
        if (cbGetFeatureCount() >= 3) return;
        document.getElementById('cb-features-empty').style.display = 'none';
        const id = 'cbfeat-' + (++window._cbUidFeature);
        const num = cbGetFeatureCount() + 1;
        const titleVal = (prefill && prefill.title) || '';
        const descVal = (prefill && prefill.description) || '';
        // Store db id if this is an existing record
        if (prefill && prefill.id) window._cbFeatureDbIds[id] = prefill.id;
        const div = document.createElement('div');
        div.className = 'cb-feature-item';
        div.id = id;
        div.innerHTML = `
        <div class="cb-feature-head">
            <span class="cb-feature-label">⭐ Feature ${num}</span>
            <button type="button" class="cb-btn-delete" onclick="cbDeleteFeature('${id}')">🗑 Delete</button>
        </div>
        <div class="cb-field">
            <label class="cb-label">Title <span class="req">*</span></label>
            <input type="text" class="cb-control feat-title" placeholder="e.g. Lightning Fast Performance"
                value="${titleVal.replace(/"/g, '&quot;')}" oninput="cbMarkChanged('cb-basic-changed')">
        </div>
        <div class="cb-field" style="margin-bottom:0">
            <label class="cb-label">Description</label>
            <textarea class="cb-control feat-desc" placeholder="Briefly describe this feature…" rows="3"
                oninput="cbMarkChanged('cb-basic-changed')">${descVal}</textarea>
        </div>
    `;
        document.getElementById('cb-features-container').appendChild(div);
        cbUpdateFeaturesUI();
        cbRenumberFeatures();
    }
    function cbDeleteFeature(id) {
        const el = document.getElementById(id);
        if (!el) return;
        el.style.animation = 'cbFadeOut 0.18s ease forwards';
        delete window._cbFeatureDbIds[id];
        setTimeout(() => {
            el.remove();
            cbUpdateFeaturesUI();
            cbRenumberFeatures();
            if (!document.querySelector('.cb-feature-item')) document.getElementById('cb-features-empty').style.display = 'block';
        }, 180);
        cbMarkChanged('cb-basic-changed');
    }
    function cbRenumberFeatures() {
        document.querySelectorAll('.cb-feature-item .cb-feature-label').forEach((el, i) => { el.textContent = `⭐ Feature ${i + 1}`; });
    }

    // ════════════════════════════════════════
    // META TITLE AUTO-SYNC
    // ════════════════════════════════════════
    (function () {
        let manualEdit = false;
        const titleInput = document.getElementById('cb-title');
        const metaInput = document.getElementById('cb-meta-title');
        const badge = document.getElementById('cb-sync-badge');
        titleInput.addEventListener('input', function () {
            if (!manualEdit) {
                metaInput.value = this.value;
                badge.classList.add('show');
                clearTimeout(badge._t);
                badge._t = setTimeout(() => badge.classList.remove('show'), 1600);
            }
        });
        metaInput.addEventListener('input', function () {
            manualEdit = this.value !== titleInput.value;
        });
    })();

    // ════════════════════════════════════════
    // TOAST
    // ════════════════════════════════════════
    function cbToast(msg, type = 'info', duration = 3500) {
        const icons = { success: '✅', error: '❌', info: '💬' };
        const toast = document.getElementById('cb-toast');
        toast.innerHTML = `${icons[type] || '💬'} ${msg}`;
        toast.className = `cb-toast ${type} show`;
        clearTimeout(toast._t);
        toast._t = setTimeout(() => toast.classList.remove('show'), duration);
    }

    // ════════════════════════════════════════
    // DELETE MODAL
    // ════════════════════════════════════════
    function cbOpenDeleteModal() {
        document.getElementById('cb-delete-modal').classList.add('show');
    }
    function cbCloseDeleteModal() {
        document.getElementById('cb-delete-modal').classList.remove('show');
    }
    document.getElementById('cb-delete-modal').addEventListener('click', function (e) {
        if (e.target === this) cbCloseDeleteModal();
    });
    async function cbConfirmDelete() {
        const btn = document.getElementById('cb-confirm-delete-btn');
        btn.textContent = 'Deleting…';
        btn.disabled = true;
        try {
            await axios.delete(`/admin/blogs/delete/${BLOG_ID}`);
            cbCloseDeleteModal();
            cbToast('Blog post deleted successfully', 'success', 3000);
            setTimeout(() => { window.location.href = '/admin/blogs'; }, 1500);
        } catch (err) {
            const msg = err.response?.data?.message || err.message || 'Delete failed';
            cbToast(`Error: ${msg}`, 'error');
            btn.textContent = 'Yes, Delete';
            btn.disabled = false;
            cbCloseDeleteModal();
            setTimeout(() => { window.location.href = '/admin/blogs'; }, 1);


        }
    }

    // ════════════════════════════════════════
    // LOAD EXISTING DATA
    // ════════════════════════════════════════
    async function cbLoadBlogData() {
        try {
            // ── REAL API CALL — uncomment and remove demo data below ──
            const res = await axios.get(`/admin/blogs/data/${BLOG_ID}`);
            const blog = res.data.data.blog;

            cbPopulateForm(blog);

        } catch (err) {
            cbToast('Failed to load blog data. Please refresh.', 'error', 6000);
        }
    }

    function cbPopulateForm(blog) {
        // Basic fields
        document.getElementById('cb-title').value = blog.title || '';
        document.getElementById('cb-status').value = blog.status || 'draft';

        // Hero image — API uses `hero_image` field
        const heroUrl = blog.hero_image || blog.hero_image_url || null;
        if (heroUrl) {
            document.getElementById('hero-current-img').src = heroUrl;
            document.getElementById('hero-current').style.display = 'block';
            document.getElementById('hero-replace-area').style.display = 'none';
        } else {
            cbShowHeroReplace();
        }

        // Tags — API may not return tags; handle gracefully
        const tags = blog.tags || [];
        if (tags.length) {
            tags.forEach(t => {
                if (!window._cbAllTags.find(a => a.id === t.id)) window._cbAllTags.push(t);
                window._cbSelectedTags.push(t);
            });
            // Re-render chips
            const display = document.getElementById('cb-tag-display');
            const input = document.getElementById('cb-tag-search');
            window._cbSelectedTags.forEach(tag => {
                const chip = document.createElement('div');
                chip.className = 'cb-tag-chip';
                chip.innerHTML = `${tag.name} <span class="rm" onclick="event.stopPropagation();cbRemoveTag(${tag.id})">×</span>`;
                display.insertBefore(chip, input);
            });
        }

        // Sections — sorted by sort_order, supports section_type field from API
        const sections = (blog.sections || []).slice().sort((a, b) => (a.sort_order || 0) - (b.sort_order || 0));
        sections.forEach(s => cbAddSection(s));

        // Features — sorted by sort_order
        const features = (blog.features || []).slice().sort((a, b) => (a.sort_order || 0) - (b.sort_order || 0));
        features.forEach(f => cbAddFeature(f));

        // SEO
        document.getElementById('cb-meta-title').value = blog.meta_title || '';
        document.getElementById('cb-meta-desc').value = blog.meta_description || '';
        document.getElementById('cb-meta-keywords').value = blog.meta_keywords || '';

        // Updated at
        const dateStr = blog.updated_at || blog.created_at;
        if (dateStr) {
            const d = new Date(dateStr);
            document.getElementById('cb-last-updated').textContent = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' });
        }

        // Preview link — use slug if available
        const previewPath = blog.preview_url || (blog.slug ? `/blog/${blog.slug}` : '#');
        document.getElementById('cb-preview-link').href = previewPath;
    }

    // ════════════════════════════════════════
    // SUBMIT / UPDATE
    // ════════════════════════════════════════
    async function cbSubmitForm() {
        const title = document.getElementById('cb-title').value.trim();
        const metaTitle = document.getElementById('cb-meta-title').value.trim();
        const metaDesc = document.getElementById('cb-meta-desc').value.trim();
        const heroReplaceVisible = document.getElementById('hero-replace-area').style.display !== 'none';
        const heroInput = document.getElementById('hero-input');

        if (!title) { cbToast('Blog title is required', 'error'); return; }
        if (heroReplaceVisible && !heroInput.files[0]) { cbToast('Please upload a replacement hero image or cancel the replacement', 'error'); return; }
        if (!metaTitle) { cbToast('Meta title is required', 'error'); return; }
        if (!metaDesc) { cbToast('Meta description is required', 'error'); return; }

        const featCount = cbGetFeatureCount();
        if (featCount > 0 && featCount < 2) { cbToast('Add at least 2 features, or remove all features', 'error'); return; }

        let featuresValid = true;
        document.querySelectorAll('.cb-feature-item').forEach(item => { if (!item.querySelector('.feat-title').value.trim()) featuresValid = false; });
        if (!featuresValid) { cbToast('Each feature must have a title', 'error'); return; }

        let sectionsValid = true;
        document.querySelectorAll('.cb-section-item').forEach(item => {
            const id = item.id;
            const select = item.querySelector('select');
            if (select.value === 'IMAGE' && !window._cbSectionFiles[id] && !window._cbSectionExisting[id]) sectionsValid = false;
        });
        if (!sectionsValid) { cbToast('All image sections must have an image selected', 'error'); return; }

        const fd = new FormData();
        fd.append('_method', 'PUT');
        fd.append('title', title);
        fd.append('status', document.getElementById('cb-status').value);

        if (heroReplaceVisible && heroInput.files[0]) {
            fd.append('hero_image', heroInput.files[0]);
        }

        window._cbSelectedTags.forEach(t => fd.append('tags[]', t.id));

        // Sections — use section_type to match API, include db id if existing record
        document.querySelectorAll('.cb-section-item').forEach((item, i) => {
            const id = item.id;
            const type = item.querySelector('select').value;
            fd.append(`sections[${i}][section_type]`, type);
            fd.append(`sections[${i}][sort_order]`, i + 1);
            // Include db id for existing records (so backend can update vs insert)
            if (window._cbSectionDbIds[id]) {
                fd.append(`sections[${i}][id]`, window._cbSectionDbIds[id]);
            }
            if (type === 'TEXT') {
                fd.append(`sections[${i}][content]`, item.querySelector('textarea').value);
            } else {
                if (window._cbSectionFiles[id]) {
                    // New file uploaded — replace existing
                    fd.append(`sections[${i}][image]`, window._cbSectionFiles[id]);
                } else if (window._cbSectionExisting[id]) {
                    // No new file — keep existing (send back url + public_id so backend knows)
                    fd.append(`sections[${i}][image_url]`, window._cbSectionExisting[id].url);
                    if (window._cbSectionExisting[id].public_id) {
                        fd.append(`sections[${i}][image_public_id]`, window._cbSectionExisting[id].public_id);
                    }
                }
            }
        });

        // Features — include db id for existing records
        document.querySelectorAll('.cb-feature-item').forEach((item, i) => {
            if (window._cbFeatureDbIds[item.id]) {
                fd.append(`features[${i}][id]`, window._cbFeatureDbIds[item.id]);
            }
            fd.append(`features[${i}][title]`, item.querySelector('.feat-title').value.trim());
            fd.append(`features[${i}][description]`, item.querySelector('.feat-desc').value.trim());
            fd.append(`features[${i}][sort_order]`, i + 1);
        });

        fd.append('meta_title', metaTitle);
        fd.append('meta_description', metaDesc);
        fd.append('meta_keywords', document.getElementById('cb-meta-keywords').value.trim());

        const saveBtn = document.getElementById('cb-save-btn');
        saveBtn.classList.add('loading');
        saveBtn.disabled = true;

        try {
            const response = await axios.put(`/admin/blogs/update/${BLOG_ID}`, fd, {
                onUploadProgress: (progressEvent) => {
                    if (progressEvent.total) {
                        const pct = Math.round((progressEvent.loaded / progressEvent.total) * 100);
                        document.querySelector('#cb-save-btn .btn-text').textContent = `Uploading… ${pct}%`;
                    }
                }
            });

            cbToast('Blog post updated successfully! 🎉', 'success', 4000);
            document.querySelector('#cb-save-btn .btn-text').textContent = '✅ Updated!';
            document.getElementById('cb-basic-changed').style.display = 'none';

            // Update "last updated" timestamp
            document.getElementById('cb-last-updated').textContent = new Date().toLocaleDateString('en-US', {
                month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit'
            });

            setTimeout(() => {
                document.querySelector('#cb-save-btn .btn-text').textContent = '✏️ Update Blog Post';
                saveBtn.classList.remove('loading');
                saveBtn.disabled = false;
            }, 2500);

        } catch (err) {
            const msg = err.response?.data?.message || err.message || 'Something went wrong';
            cbToast(`Error: ${msg}`, 'error', 5000);
            document.querySelector('#cb-save-btn .btn-text').textContent = '✏️ Update Blog Post';
            saveBtn.classList.remove('loading');
            saveBtn.disabled = false;
        }
    }

    // ════════════════════════════════════════
    // INIT
    // ════════════════════════════════════════
    document.addEventListener('DOMContentLoaded', cbLoadBlogData);
</script>