        <div class="cb-card-body">
            <div class="cb-field cb-sync-wrap">
                <label class="cb-label">Meta Title <span class="req">*</span></label>
                <input type="text" id="cb-meta-title" class="cb-control" placeholder="Auto-filled from blog title"
                    required>
