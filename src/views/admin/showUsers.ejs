<!-- Flatpickr CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<style>
    .flatpickr-calendar {
        font-family: inherit;
        border-radius: 10px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
        border: none;
    }

    .flatpickr-day.selected,
    .flatpickr-day.selected:hover {
        background: #212529;
        border-color: #212529;
    }

    .flatpickr-day:hover {
        background: #e9ecef;
    }

    .flatpickr-months .flatpickr-month,
    .flatpickr-weekdays,
    span.flatpickr-weekday {
        background: #212529;
        color: #fff;
    }

    .flatpickr-current-month .flatpickr-monthDropdown-months,
    .flatpickr-current-month input.cur-year {
        color: #fff;
    }

    .flatpickr-next-month svg,
    .flatpickr-prev-month svg {
        fill: #fff;
    }
</style>

<div class="app-content-header">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <h3 class="mb-0 fw-bold">Users</h3>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">

        <!-- Filters -->
        <form method="GET" class="row g-3 mb-3">

            <!-- Search -->
            <div class="col-md-3">
                <input type="text" name="search" value="<%= query.search || '' %>" class="form-control"
                    placeholder="Search by name or email" />
            </div>

            <!-- Role Filter -->
            <div class="col-md-2">
                <select name="role" class="form-select">
                    <option value="">All Roles</option>
                    <option value="USER" <%=query.role==='USER' ? 'selected' : '' %>>USER</option>
                    <option value="ADMIN" <%=query.role==='ADMIN' ? 'selected' : '' %>>ADMIN</option>
                </select>
            </div>

            <!-- Status Filter -->
            <div class="col-md-2">
                <select name="is_active" class="form-select">
                    <option value="">All Status</option>
                    <option value="ACTIVE" <%=query.is_active==='ACTIVE' ? 'selected' : '' %>>Active</option>
                    <option value="INACTIVE" <%=query.is_active==='INACTIVE' ? 'selected' : '' %>>Inactive</option>
                </select>
            </div>

            <!-- From Date -->
            <!-- <div class="col-md-2">
                <label class="form-label text-muted small mb-1">From Date</label>
                <div class="input-group">
                    <input type="text" id="date_from" name="date_from" value="<%= query.date_from || '' %>"
                        class="form-control" placeholder="dd-mm-yyyy" autocomplete="off" />
                    <span class="input-group-text bg-dark text-white" style="cursor:pointer"
                        onclick="document.getElementById('date_from')._flatpickr.open()">
                        <i class="bi bi-calendar3"></i>
                    </span>
                </div>
            </div>

            <div class="col-md-2">
                <label class="form-label text-muted small mb-1">To Date</label>
                <div class="input-group">
                    <input type="text" id="date_to" name="date_to" value="<%= query.date_to || '' %>"
                        class="form-control" placeholder="dd-mm-yyyy" autocomplete="off" />
                    <span class="input-group-text bg-dark text-white" style="cursor:pointer"
                        onclick="document.getElementById('date_to')._flatpickr.open()">
                        <i class="bi bi-calendar3"></i>
                    </span>
                </div>
            </div> -->

            <!-- Buttons -->
            <div class="col-md-1 d-flex gap-2 align-items-end">
                <button type="submit" class="btn btn-dark w-50" title="Apply">
                    <i class="bi bi-search"></i>
                </button>
                <a href="?" class="btn btn-outline-secondary w-50" title="Reset">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>

        <!-- Table -->
        <div class="card card-dark">
            <div class="card-body table-responsive p-0">
                <table class="table table-hover text-nowrap">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Joined</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(u=> { %>
                            <tr>
                                <td>
                                    <%= u.id %>
                                </td>
                                <td>
                                    <%= u.name || "-" %>
                                </td>
                                <td>
                                    <%= u.email || "-" %>
                                </td>
                                <td>
                                    <%= u.phone || "-" %>
                                </td>
                                <td>
                                    <span class="badge bg-<%= u.role === 'ADMIN' ? 'danger' : 'secondary' %>">
                                        <%= u.role %>
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-<%= u.status === 'ACTIVE' ? 'success' : 'warning' %>">
                                        <%= u.status  %>
                                    </span>
                                </td>
                                <td>
                                    <%= u.created_at ? new Date(u.created_at).toLocaleDateString('en-IN') : "-" %>
                                </td>
                            </tr>
                            <% }) %>

                                <% if (users.length===0) { %>
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">No users found.</td>
                                    </tr>
                                    <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Pagination -->
        <nav class="mt-3">
            <ul class="pagination justify-content-end">
                <% for(let i=1; i <=totalPages; i++) { %>
                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                        <a class="page-link"
                            href="?page=<%= i %>&search=<%= query.search || '' %>&role=<%= query.role || '' %>&is_active=<%= query.is_active || '' %>&date_from=<%= query.date_from || '' %>&date_to=<%= query.date_to || '' %>">
                            <%= i %>
                        </a>
                    </li>
                    <% } %>
            </ul>
        </nav>

    </div>
</div>

<!-- Flatpickr JS -->
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
    flatpickr("#date_from", {
        dateFormat: "Y-m-d",
        altInput: true,
        altFormat: "d-m-Y",
        allowInput: true
    });
    flatpickr("#date_to", {
        dateFormat: "Y-m-d",
        altInput: true,
        altFormat: "d-m-Y",
        allowInput: true
    });
</script>