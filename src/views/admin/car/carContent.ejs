    <script>
        (function () {
            const car = <%- JSON.stringify(car || null) %>;

            const routeContent = <%- existingContent || "null" %>;

            const existingContent = routeContent && typeof routeContent === "object"
                ? (routeContent.content && typeof routeContent.content === "object" ? routeContent.content : JSON.parse(routeContent.content))
                : null;
            const hasExistingContent = !!(
                existingContent &&
                typeof existingContent === "object" &&
                Object.keys(existingContent).length
            );

            const fallbackContent = {
                seo: {},
                hero: {},
                specs: {
                    heading: "",
                    cards: [
                        { icon: "⚡", value: "3.9s", label: "0–100 km/h" },
                        { icon: "🔧", value: "V8", label: "Twin-Turbo Engine" },
                        { icon: "💪", value: "600 hp", label: "Total Power" },
                        { icon: "👥", value: "5 Seats", label: "Executive Seating" },
                        { icon: "🧳", value: "3 Bags", label: "Boot Space" },
                    ],
                },
                feature_highlight: {
                    heading1: "",
                    heading2: "",
                    description: "",
                    stats: [
                        { value: "600 hp", label: "Twin-Turbo Power" },
                        { value: "5-Star", label: "Cabin Comfort" },
                    ],
                },
                premium_cards: {
                    heading: "",
                    subtext: "",
                    cards: [
                        {
                            title: "V8 Twin-Turbo Engine",
                            description: "4.4-litre twin-turbo V8 delivering explosive acceleration with effortless highway composure.",
                            badge: "PREMIUM FEATURE",
                        },
                        {
                            title: "M Sport Red Body Kit",
                            description: "Factory-fitted front splitter, side skirts, and rear diffuser for an unmistakable visual presence.",
                            badge: "PREMIUM FEATURE",
                        },
                        {
                            title: "Executive Leather Cabin",
                            description: "Sport Merino leather seats, ambient lighting, and premium audio for all five passengers.",
                            badge: "PREMIUM FEATURE",
                        },
                    ],
                },
            };
            let initialContent = hasExistingContent ? existingContent : fallbackContent;
            initialContent = { ...initialContent, car: { ...car } }; // Deep merge can be implemented if needed
            /* ── HELPERS ── */
            function showAlert(msg, type = "danger") {
                const c = document.getElementById("alertContainer");
                const icon = type === "success" ? "check-circle-fill" : type === "warning" ? "exclamation-triangle-fill" : "x-circle-fill";
                c.innerHTML = `<div class="custom-alert ${type}"><i class="bi bi-${icon}"></i>${msg}</div>`;
                c.scrollIntoView({ behavior: "smooth" });
                setTimeout(() => { c.innerHTML = ""; }, 5000);
            }

            window.setActive = function (el) {
                document.querySelectorAll(".editor-nav-item").forEach(n => n.classList.remove("active"));
                el.classList.add("active");
            };

            window.markDone = function (btn) {
                btn.innerHTML = `<i class="bi bi-check2-circle" style="color:var(--success)"></i> <span style="color:var(--success)">Done ✓</span>`;
                btn.style.borderColor = "var(--success)";
                setTimeout(() => {
                    btn.innerHTML = `<i class="bi bi-check2-circle"></i> Mark as Done`;
                    btn.style.borderColor = "";
                }, 2500);
            };

            /* ── GENERIC REPEATABLE ── */
            function makeRepeatable(containerId, templateId, itemClass, addBtnId) {
                const container = document.getElementById(containerId);
                const addBtn = document.getElementById(addBtnId);

                function renumber() {
                    container.querySelectorAll("." + itemClass).forEach((el, i) => {
                        el.querySelector(".item-num").textContent = i + 1;
                    });
                }

                function addItem(data = {}) {
                    const clone = document.getElementById(templateId).content.cloneNode(true);
                    const card = clone.querySelector("." + itemClass);
                    Object.entries(data).forEach(([key, val]) => {
                        const el = card.querySelector(".f-" + key);
                        if (el) el.value = val;
                    });
                    card.querySelector(".remove-btn").addEventListener("click", function () {
                        this.closest("." + itemClass).remove();
                        renumber();
                    });
                    container.appendChild(clone);
                    renumber();
                }

                addBtn.addEventListener("click", () => addItem());
                return { addItem, renumber };
            }

            /* ── INIT REPEATABLES ── */
            const specCards = makeRepeatable("specCardsContainer", "tpl-spec-card", "spec-card-item", "addSpecCardBtn");
            const fhStats = makeRepeatable("fhStatsContainer", "tpl-fh-stat", "fh-stat-item", "addFhStatBtn");
            const premiumCards = makeRepeatable("premiumCardsContainer", "tpl-premium-card", "premium-card-item", "addPremiumCardBtn");
            // const faqs = makeRepeatable("faqContainer", "tpl-faq", "faq-item", "addFaqBtn");
            // const testimonials = makeRepeatable("testimonialsContainer", "tpl-testimonial", "testimonial-item", "addTestimonialBtn");

            function setValue(id, value) {
                const el = document.getElementById(id);
                if (el) el.value = value || "";
            }

            function hydrateFields(data) {
                console.log(data);

                const seo = data.seo || {};
                const hero = data.hero || {};
                const specs = data.specs || {};
                const featureHighlight = data.feature_highlight || {};
                const premiumCardsData = data.premium_cards || {};
                const car = data.car || {};
                setValue("seo_title", seo.title);
                setValue("seo_description", seo.description);
                setValue("seo_h1", seo.h1);

                setValue("hero_brand", car.Brand?.brand_name || "");
                setValue("hero_car_name", car.name);
                setValue("hero_description", hero.description);
                setValue("hero_rating", hero.rating);
                setValue("hero_bookings", hero.bookings);
                setValue("hero_price", hero.price);
                setValue("hero_price_label", hero.price_label);
                setValue("hero_btn_text", hero.btn_text);
                setValue("hero_btn_link", hero.btn_link);

                setValue("specs_heading", specs.heading);
                (Array.isArray(specs.cards) ? specs.cards : []).forEach(card => specCards.addItem(card));

                setValue("fh_heading1", featureHighlight.heading1);
                setValue("fh_heading2", featureHighlight.heading2);
                setValue("fh_description", featureHighlight.description);
                (Array.isArray(featureHighlight.stats) ? featureHighlight.stats : []).forEach(stat => fhStats.addItem(stat));

                setValue("pc_heading", premiumCardsData.heading);
                setValue("pc_subtext", premiumCardsData.subtext);
                (Array.isArray(premiumCardsData.cards) ? premiumCardsData.cards : []).forEach(card => premiumCards.addItem(card));
            }

            function syncSeoPreview() {
                document.getElementById("seo_preview_title").textContent = document.getElementById("seo_title").value || "Page title will appear here";
                document.getElementById("seo_preview_desc").textContent = document.getElementById("seo_description").value || "Meta description will appear here…";
            }

            function updateCounters() {
                ["seo_title", "seo_description"].forEach(id => {
                    document.getElementById(id)?.dispatchEvent(new Event("input"));
                });
            }

            hydrateFields(initialContent);

            // faqs.addItem({ question: "Is fuel included in the booking?", answer: "Yes, fuel is fully included in all our bookings. No extra charges at the end." });
            // faqs.addItem({ question: "Do you provide a uniformed chauffeur?", answer: "Absolutely. A professional uniformed chauffeur is included with every booking." });

            // testimonials.addItem({ name: "Rahul Mehta", location: "Mumbai", rating: "5", review: "Absolutely stunning car. The BMW M5 made our wedding convoy unforgettable. Highly recommend Sun Venus!", date: "March 2025" });

            /* ── SEO CHAR COUNTERS ── */
            function charCounter(inputId, counterId, max) {
                const input = document.getElementById(inputId);
                const counter = document.getElementById(counterId);
                if (!input || !counter) return;
                input.addEventListener("input", () => {
                    const len = input.value.length;
                    counter.textContent = `${len} / ${max}`;
                    counter.className = "char-counter" + (len > max ? " over" : len > max * .85 ? " warn" : "");
                });
            }
            charCounter("seo_title", "seo_title_count", 60);
            charCounter("seo_description", "seo_description_count", 160);

            // SEO live preview
            ["seo_title", "seo_description"].forEach(id => {
                document.getElementById(id)?.addEventListener("input", () => {
                    syncSeoPreview();
                });
            });

            document.getElementById("seo_preview_url").textContent = car?.slug
                ? `sunvenus.com › cars › ${car.slug}`
                : "sunvenus.com › cars › car-slug";
            updateCounters();
            syncSeoPreview();

            /* ── COLLECT DATA ── */
            function collectData() {
                return {
                    seo: {
                        title: document.getElementById("seo_title").value.trim(),
                        description: document.getElementById("seo_description").value.trim(),
                        h1: document.getElementById("seo_h1").value.trim(),
                    },
                    hero: {
                        brand: document.getElementById("hero_brand").value.trim(),
                        car_name: document.getElementById("hero_car_name").value.trim(),
                        description: document.getElementById("hero_description").value.trim(),
                        rating: document.getElementById("hero_rating").value.trim(),
                        bookings: document.getElementById("hero_bookings").value.trim(),
                        price: document.getElementById("hero_price").value.trim(),
                        price_label: document.getElementById("hero_price_label").value.trim(),
                        btn_text: document.getElementById("hero_btn_text").value.trim(),
                        btn_link: document.getElementById("hero_btn_link").value.trim(),
                    },
                    specs: {
                        heading: document.getElementById("specs_heading").value.trim(),
                        cards: Array.from(document.querySelectorAll(".spec-card-item")).map(el => ({
                            icon: el.querySelector(".f-icon").value.trim(),
                            value: el.querySelector(".f-value").value.trim(),
                            label: el.querySelector(".f-label").value.trim(),
                        })),
                    },
                    feature_highlight: {
                        heading1: document.getElementById("fh_heading1").value.trim(),
                        heading2: document.getElementById("fh_heading2").value.trim(),
                        description: document.getElementById("fh_description").value.trim(),
                        stats: Array.from(document.querySelectorAll(".fh-stat-item")).map(el => ({
                            value: el.querySelector(".f-value").value.trim(),
                            label: el.querySelector(".f-label").value.trim(),
                        })),
                    },
                    premium_cards: {
                        heading: document.getElementById("pc_heading").value.trim(),
                        subtext: document.getElementById("pc_subtext").value.trim(),
                        cards: Array.from(document.querySelectorAll(".premium-card-item")).map(el => ({
                            title: el.querySelector(".f-title").value.trim(),
                            description: el.querySelector(".f-description").value.trim(),
                            badge: el.querySelector(".f-badge").value.trim(),
                        })),
                    },
                    // faq: {
                    //     heading: document.getElementById("faq_heading").value.trim(),
                    //     items: Array.from(document.querySelectorAll(".faq-item")).map(el => ({
                    //         question: el.querySelector(".f-question").value.trim(),
                    //         answer: el.querySelector(".f-answer").value.trim(),
                    //     })),
                    // },
                    // testimonials: {
                    //     heading: document.getElementById("test_heading").value.trim(),
                    //     items: Array.from(document.querySelectorAll(".testimonial-item")).map(el => ({
                    //         name: el.querySelector(".f-name").value.trim(),
                    //         location: el.querySelector(".f-location").value.trim(),
                    //         rating: parseInt(el.querySelector(".f-rating").value),
                    //         review: el.querySelector(".f-review").value.trim(),
                    //         date: el.querySelector(".f-date").value.trim(),
                    //     })),
                    // },
                };
            }

            /* ── VALIDATE ── */
            function validate(d) {
                if (!d.seo.title) return "SEO: Page title is required.";
                if (!d.seo.description) return "SEO: Meta description is required.";
                if (!d.seo.h1) return "SEO: H1 heading is required.";
                if (!d.hero.brand) return "Hero: Brand name is required.";
                if (!d.hero.car_name) return "Hero: Car name is required.";
                if (!d.hero.price) return "Hero: Price is required.";
                if (!d.hero.btn_link) return "Hero: Book Now button link is required.";
                if (!d.specs.cards.length) return "Specs: Add at least one spec card.";
                for (let i = 0; i < d.specs.cards.length; i++) {
                    if (!d.specs.cards[i].value || !d.specs.cards[i].label)
                        return `Spec Card #${i + 1}: Value and Label are required.`;
                }
                for (let i = 0; i < d.premium_cards.cards.length; i++) {
                    if (!d.premium_cards.cards[i].title || !d.premium_cards.cards[i].description)
                        return `Premium Card #${i + 1}: Title and Description are required.`;
                }
                // for (let i = 0; i < d.faq.items.length; i++) {
                //     if (!d.faq.items[i].question || !d.faq.items[i].answer)
                //         return `FAQ #${i + 1}: Question and Answer are required.`;
                // }
                // for (let i = 0; i < d.testimonials.items.length; i++) {
                //     if (!d.testimonials.items[i].name || !d.testimonials.items[i].review)
                //         return `Testimonial #${i + 1}: Name and Review are required.`;
                // }
                return null;
            }

            /* ── SAVE ALL ── */
            async function saveAll(btn) {
                btn.disabled = true;
                btn.innerHTML = `<span class="spinner-border spinner-border-sm me-1" style="width:13px;height:13px;border-width:2px;"></span> Saving…`;

                const data = collectData();
                console.log(data);
                
                const err = validate(data);
                if (err) {
                    showAlert(err, "danger");
                    btn.disabled = false;
                    btn.innerHTML = `<i class="bi bi-floppy2-fill"></i> Save All Sections`;
                    return;
                }

                try {
                    const carId = car?.id || window.location.pathname.split("/")[3] || "1";

                    const res = await fetch(`/admin/car/${carId}/content`, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(data),
                    });
                    const json = await res.json().catch(() => ({}));

                    if (!res.ok) {
                        showAlert(json.message || "Failed to save content.", "danger");
                    } else {
                        showAlert("All content saved successfully!", "success");
                        document.getElementById("saveStatus").textContent = "Saved at " + new Date().toLocaleTimeString();
                    }
                } catch (e) {
                    console.error(e);
                    showAlert("Network error. Please try again.", "danger");
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = `<i class="bi bi-floppy2-fill"></i> Save All Sections`;
                }
            }

            document.getElementById("saveAllBtn").addEventListener("click", function () { saveAll(this); });
            document.getElementById("saveAllBtnBottom").addEventListener("click", function () { saveAll(document.getElementById("saveAllBtn")); });

            /* ── SIDEBAR ACTIVE ON SCROLL ── */
            const sections = ["sec-seo", "sec-hero", "sec-specs", "sec-feature-highlight", "sec-premium-cards", "sec-faq", "sec-testimonials"];
            const navLinks = document.querySelectorAll(".editor-nav-item[href^='#']");
            window.addEventListener("scroll", () => {
                let current = "";
                sections.forEach(id => {
                    const el = document.getElementById(id);
                    if (el && el.getBoundingClientRect().top <= 100) current = id;
                });
                navLinks.forEach(link => {
                    link.classList.toggle("active", link.getAttribute("href") === "#" + current);
                });
            });

        })();
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>