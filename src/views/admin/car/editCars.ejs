<div class="app-content-header">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <h3 class="mb-0 fw-bold">Edit Car</h3>
        <span class="text-muted">Cars / Edit — <%= car.name %></span>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">

        <!-- Alert Container -->
        <div id="alertContainer"></div>

        <div class="row">
            <div class="col-12">
                <div class="card card-primary">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="bi bi-car-front-fill me-2"></i>Car Details
                        </h3>
                    </div>
                    <div class="card-body">

                        <!-- Basic Info -->
                        <h5 class="fw-semibold text-muted mb-3 border-bottom pb-2">
                            <i class="bi bi-info-circle me-1"></i> Basic Information
                        </h5>
                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Car Name <span
                                        class="text-danger">*</span></label>
                                <input type="text" id="name" class="form-control" placeholder="e.g. Maybach S580"
                                    value="<%= car.name || '' %>" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Model <span class="text-danger">*</span></label>
                                <input type="text" id="model" class="form-control" placeholder="e.g. S-Class"
                                    value="<%= car.model || '' %>" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Color <span class="text-danger">*</span></label>
                                <input type="text" id="color" class="form-control" placeholder="e.g. Obsidian Black"
                                    value="<%= car.color || '' %>" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Brand <span class="text-danger">*</span></label>
                                <select id="brand_id" class="form-select">
                                    <option value="">-- Select Brand --</option>
                                    <% brands.forEach(brand=> { %>
                                        <option value="<%= brand.id %>" <%=car.brand_id===brand.id ? 'selected' : '' %>>
                                            <%= brand.brand_name %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Category <span
                                        class="text-danger">*</span></label>
                                <select id="category_id" class="form-select">
                                    <option value="">-- Select Category --</option>
                                    <% categories.forEach(cat=> { %>
                                        <option value="<%= cat.id %>" <%=car.category_id===cat.id ? 'selected' : '' %>>
                                            <%= cat.category %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Fuel Type <span
                                        class="text-danger">*</span></label>
                                <select id="fuel_type_id" class="form-select">
                                    <option value="">-- Select Fuel Type --</option>
                                    <% fuelTypes.forEach(fuel=> { %>
                                        <option value="<%= fuel.id %>" <%=car.fuel_type_id===fuel.id ? 'selected' : ''
                                            %>>
                                            <%= fuel.fuel %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Transmission <span
                                        class="text-danger">*</span></label>
                                <select id="transmission" class="form-select">
                                    <option value="">-- Select --</option>
                                    <option value="MANUAL" <%=car.transmission==='MANUAL' ? 'selected' : '' %>>Manual
                                    </option>
                                    <option value="AUTOMATIC" <%=car.transmission==='AUTOMATIC' ? 'selected' : '' %>
                                        >Automatic</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Seating Capacity <span
                                        class="text-danger">*</span></label>
                                <input type="number" id="seating_capacity" class="form-control" placeholder="e.g. 5"
                                    min="1" max="20" value="<%= car.seating_capacity || '' %>" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Order By</label>
                                <input type="number" id="order_by" class="form-control" placeholder="0" min="0"
                                    value="<%= car.order_by ?? 0 %>" />
                            </div>
                        </div>

                        <!-- Flags -->
                        <h5 class="fw-semibold text-muted mb-3 border-bottom pb-2">
                            <i class="bi bi-toggle-on me-1"></i> Flags
                        </h5>
                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="is_active" <%=car.is_active
                                        ? 'checked' : '' %> />
                                    <label class="form-check-label fw-semibold" for="is_active">Is Active</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="is_premium" <%=car.is_premium
                                        ? 'checked' : '' %> />
                                    <label class="form-check-label fw-semibold" for="is_premium">Is Premium</label>
                                </div>
                            </div>
                        </div>

                        <!-- Pricing -->
                        <h5 class="fw-semibold text-muted mb-3 border-bottom pb-2">
                            <i class="bi bi-currency-rupee me-1"></i> Pricing
                        </h5>
                        <div id="pricingRows">
                            <!-- Existing pricing rows injected by JS below -->
                        </div>
                        <button type="button" class="btn btn-outline-primary btn-sm mt-2 mb-4" id="addPricingBtn">
                            <i class="bi bi-plus-circle me-1"></i> Add Pricing Tier
                        </button>

                        <!-- Existing Images -->
                        <h5 class="fw-semibold text-muted mb-3 border-bottom pb-2">
                            <i class="bi bi-images me-1"></i> Existing Images
                        </h5>
                        <div id="existingImagesContainer" class="row g-3 mb-4">
                            <% const carImages=car.CarImages || []; %>
                                <% if (carImages.length> 0) { %>
                                    <% carImages.forEach(img=> { %>
                                        <div class="col-md-3 col-sm-6 existing-image-item"
                                            id="existing-img-<%= img.id %>">
                                            <div class="card h-100 border shadow-sm">
                                                <div class="position-relative">
                                                    <% if (img.file_type==='VIDEO' ) { %>
                                                        <div class="d-flex align-items-center justify-content-center bg-dark"
                                                            style="height:160px;">
                                                            <i class="bi bi-play-circle text-white fs-1"></i>
                                                        </div>
                                                        <% } else { %>
                                                            <img src="<%= img.image_url || img.image_path %>"
                                                                alt="Car Image" class="card-img-top"
                                                                style="height:160px;object-fit:cover;"
                                                                onerror="this.src='https://via.placeholder.com/300x160/dee2e6/6c757d?text=No+Image'" />
                                                            <% } %>
                                                                <span
                                                                    class="badge bg-dark position-absolute top-0 start-0 m-1">
                                                                    <%= img.file_type || 'IMAGE' %>
                                                                </span>
                                                                <% if (img.is_primary) { %>
                                                                    <span
                                                                        class="badge bg-success position-absolute top-0 end-0 m-1">
                                                                        <i class="bi bi-star-fill me-1"></i>Primary
                                                                    </span>
                                                                    <% } %>
                                                </div>
                                                <div class="card-body p-2">
                                                    <p class="small text-truncate text-muted mb-2">
                                                        <%= img.image_name %>
                                                    </p>
                                                    <div class="d-flex gap-1">
                                                        <% if (!img.is_primary) { %>
                                                            <button type="button"
                                                                class="btn btn-sm btn-outline-success flex-fill"
                                                                onclick="setPrimaryImage(<%= img.id %>)">
                                                                <i class="bi bi-star me-1"></i>Set Primary
                                                            </button>
                                                            <% } %>
                                                                <button type="button"
                                                                    class="btn btn-sm btn-outline-danger flex-fill"
                                                                    onclick="deleteExistingImage(<%= img.id %>)">
                                                                    <i class="bi bi-trash"></i>
                                                                </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <% }) %>
                                            <% } else { %>
                                                <div class="col-12">
                                                    <p class="text-muted">No images uploaded yet.</p>
                                                </div>
                                                <% } %>
                        </div>

                        <!-- Upload New Images -->
                        <h5 class="fw-semibold text-muted mb-3 border-bottom pb-2">
                            <i class="bi bi-cloud-upload me-1"></i> Upload New Images
                        </h5>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Upload Images / Videos</label>
                            <input type="file" id="imageFilesInput" class="form-control" multiple
                                accept="image/*,video/*" />
                            <div class="form-text">You can select multiple files. Configure each one below.</div>
                        </div>
                        <div id="imagePreviewContainer" class="row g-3 mb-4"></div>

                        <!-- Submit -->
                        <div class="d-flex gap-2 mt-3">
                            <button type="button" class="btn btn-primary px-4" id="submitCarBtn">
                                <i class="bi bi-check-circle me-1"></i> Save Changes
                            </button>
                            <a href="/admin/cars" class="btn btn-secondary px-4">
                                <i class="bi bi-x-circle me-1"></i> Cancel
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Pricing Row Template (hidden) -->
<template id="pricingRowTemplate">
    <div class="pricing-row card bg-light border mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0 fw-semibold text-primary">Pricing Tier #<span class="tier-num"></span></h6>
                <button type="button" class="btn btn-sm btn-outline-danger remove-pricing-btn">
                    <i class="bi bi-trash"></i> Remove
                </button>
            </div>
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Base Price (₹) <span
                            class="text-danger">*</span></label>
                    <input type="number" class="form-control form-control-sm pricing-base_price" placeholder="e.g. 5000"
                        min="0" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Duration (hrs) <span
                            class="text-danger">*</span></label>
                    <select class="form-select form-select-sm pricing-duration_hours">
                        <option value="">-- Select --</option>
                        <option value="8">8 hrs</option>
                        <option value="12">12 hrs</option>
                        <option value="24">24 hrs</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Included KMs <span class="text-danger">*</span></label>
                    <select class="form-select form-select-sm pricing-included_km">
                        <option value="">-- Select --</option>
                        <option value="80">80 km</option>
                        <option value="120">120 km</option>
                        <option value="250">250 km</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Extra Hour Charge (₹) <span
                            class="text-danger">*</span></label>
                    <input type="number" class="form-control form-control-sm pricing-extra_hour_charge"
                        placeholder="e.g. 500" min="0" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Extra KM Charge (₹) <span
                            class="text-danger">*</span></label>
                    <input type="number" class="form-control form-control-sm pricing-extra_km_charge"
                        placeholder="e.g. 20" min="0" />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check form-switch ms-1">
                        <input class="form-check-input pricing-is_outstation" type="checkbox" />
                        <label class="form-check-label small fw-semibold">Outstation</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
</template>

<!-- New Image Card Template (hidden) -->
<template id="imageCardTemplate">
    <div class="col-md-3 col-sm-6 image-card-item">
        <div class="card h-100 border shadow-sm">
            <div class="position-relative">
                <img src="" alt="Preview" class="card-img-top img-preview" style="height:160px;object-fit:cover;" />
                <span class="badge bg-dark position-absolute top-0 start-0 m-1 file-type-badge">IMAGE</span>
            </div>
            <div class="card-body p-2">
                <p class="small text-truncate text-muted mb-2 file-name-label"></p>
                <div class="form-check form-switch mb-1">
                    <input class="form-check-input img-is_primary" type="checkbox" />
                    <label class="form-check-label small fw-semibold">Primary Image</label>
                </div>
                <div class="form-check form-switch mb-1">
                    <input class="form-check-input img-with_bg" type="checkbox" checked />
                    <label class="form-check-label small fw-semibold">With Background</label>
                </div>
                <button type="button" class="btn btn-sm btn-outline-danger w-100 mt-1 remove-image-btn">
                    <i class="bi bi-trash me-1"></i>Remove
                </button>
            </div>
        </div>
    </div>
</template>

<script>
    (function () {

        const CAR_ID = <%= car.id %>;

        /* ─────────────────────────────────────────
           Helpers
        ───────────────────────────────────────── */
        function showAlert(msg, type = "danger") {
            const container = document.getElementById("alertContainer");
            container.innerHTML = `
            <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                ${msg}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>`;
            container.scrollIntoView({ behavior: "smooth" });
        }

        /* ─────────────────────────────────────────
           Pricing Rows
           car.CarsPricings is the association key
           because your model is named CarsPricings
        ───────────────────────────────────────── */
        let pricingCount = 0;

        const existingPricings = `<%- JSON.stringify(car.CarsPricings || []) %>`;


        function addPricingRow(prefill = null) {
            pricingCount++;
            const template = document.getElementById("pricingRowTemplate");
            const clone = template.content.cloneNode(true);
            const row = clone.querySelector(".pricing-row");

            clone.querySelector(".tier-num").textContent = pricingCount;

            if (prefill && prefill.id) {
                row.dataset.pricingId = prefill.id;
            }

            if (prefill) {
                clone.querySelector(".pricing-base_price").value = prefill.base_price || "";
                clone.querySelector(".pricing-extra_hour_charge").value = prefill.extra_hour_charge || "";
                clone.querySelector(".pricing-extra_km_charge").value = prefill.extra_km_charge || "";
                clone.querySelector(".pricing-is_outstation").checked = prefill.is_outstation || false;

                // Pre-select duration dropdown
                const durationSelect = clone.querySelector(".pricing-duration_hours");
                [...durationSelect.options].forEach(o => {
                    if (parseInt(o.value) === prefill.duration_hours) o.selected = true;
                });

                // Pre-select km dropdown
                const kmSelect = clone.querySelector(".pricing-included_km");
                [...kmSelect.options].forEach(o => {
                    if (parseInt(o.value) === prefill.included_km) o.selected = true;
                });
            }

            clone.querySelector(".remove-pricing-btn").addEventListener("click", function () {
                this.closest(".pricing-row").remove();
                renumberPricingTiers();
            });

            document.getElementById("pricingRows").appendChild(clone);
        }

        function renumberPricingTiers() {
            document.querySelectorAll(".pricing-row .tier-num").forEach((el, i) => {
                el.textContent = i + 1;
            });
            pricingCount = document.querySelectorAll(".pricing-row").length;
        }

        function getPricingData() {
            const rows = document.querySelectorAll(".pricing-row");
            const pricings = [];
            rows.forEach(row => {
                pricings.push({
                    id: parseInt(row.dataset.pricingId) || null,
                    base_price: parseInt(row.querySelector(".pricing-base_price").value) || null,
                    duration_hours: parseInt(row.querySelector(".pricing-duration_hours").value) || null,
                    included_km: parseInt(row.querySelector(".pricing-included_km").value) || null,
                    extra_hour_charge: parseInt(row.querySelector(".pricing-extra_hour_charge").value) || null,
                    extra_km_charge: parseInt(row.querySelector(".pricing-extra_km_charge").value) || null,
                    is_outstation: row.querySelector(".pricing-is_outstation").checked,
                });
            });
            return pricings;
        }

        // Load existing pricing tiers on page init
        if (existingPricings.length > 0) {

            JSON.parse(existingPricings).forEach(p => addPricingRow(p));
        } else {
            addPricingRow(); // default empty row
        }

        document.getElementById("addPricingBtn").addEventListener("click", () => addPricingRow());

        /* ─────────────────────────────────────────
           Existing Image Actions
        ───────────────────────────────────────── */
        async function deleteExistingImage(imageId) {
            if (!confirm("Are you sure you want to delete this image? This cannot be undone.")) return;
            try {
                const res = await fetch(`/admin/update/cars/${CAR_ID}/images/${imageId}`, { method: "DELETE" });
                const data = await res.json();
                if (res.ok && data.success) {
                    document.getElementById(`existing-img-${imageId}`)?.remove();
                    showAlert("Image deleted successfully.", "success");
                } else {
                    showAlert(data.message || "Failed to delete image.");
                }
            } catch {
                showAlert("An error occurred while deleting the image.");
            }
        }

        async function setPrimaryImage(imageId) {
            try {
                const res = await fetch(`/admin/update/cars/${CAR_ID}/images/${imageId}/primary`, { method: "PATCH" });
                const data = await res.json();
                if (res.ok && data.success) {
                    showAlert("Primary image updated. Reloading...", "success");
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    showAlert(data.message || "Failed to update primary image.");
                }
            } catch {
                showAlert("An error occurred.");
            }
        }

        window.deleteExistingImage = deleteExistingImage;
        window.setPrimaryImage = setPrimaryImage;

        /* ─────────────────────────────────────────
           New Image Upload Handling
        ───────────────────────────────────────── */
        let selectedFiles = [];

        document.getElementById("imageFilesInput").addEventListener("change", function (e) {
            Array.from(e.target.files).forEach(file => {
                selectedFiles.push({ file, is_primary: false, with_bg: true });
                renderImageCard(selectedFiles.length - 1);
            });
            this.value = "";
        });

        function renderImageCard(index) {
            const entry = selectedFiles[index];
            const template = document.getElementById("imageCardTemplate");
            const clone = template.content.cloneNode(true);
            const wrapper = clone.querySelector(".image-card-item");
            wrapper.dataset.fileIndex = index;

            const preview = clone.querySelector(".img-preview");
            const isVideo = entry.file.type.startsWith("video/");
            clone.querySelector(".file-type-badge").textContent = isVideo ? "VIDEO" : "IMAGE";
            clone.querySelector(".file-name-label").textContent = entry.file.name;

            if (isVideo) {
                preview.src = "https://via.placeholder.com/300x160/212529/ffffff?text=VIDEO";
            } else {
                const reader = new FileReader();
                reader.onload = ev => { preview.src = ev.target.result; };
                reader.readAsDataURL(entry.file);
            }

            const isPrimaryCheck = clone.querySelector(".img-is_primary");
            isPrimaryCheck.checked = entry.is_primary;
            isPrimaryCheck.addEventListener("change", function () {
                selectedFiles[index].is_primary = this.checked;
                if (this.checked) {
                    document.querySelectorAll(".img-is_primary").forEach(cb => {
                        const cardIndex = parseInt(cb.closest(".image-card-item").dataset.fileIndex);
                        if (cardIndex !== index) {
                            cb.checked = false;
                            selectedFiles[cardIndex].is_primary = false;
                        }
                    });
                }
            });

            clone.querySelector(".img-with_bg").checked = entry.with_bg;
            clone.querySelector(".img-with_bg").addEventListener("change", function () {
                selectedFiles[index].with_bg = this.checked;
            });

            clone.querySelector(".remove-image-btn").addEventListener("click", function () {
                selectedFiles[index] = null;
                wrapper.remove();
            });

            document.getElementById("imagePreviewContainer").appendChild(clone);
        }

        /* ─────────────────────────────────────────
           Submit — Update Car
        ───────────────────────────────────────── */
        document.getElementById("submitCarBtn").addEventListener("click", async function () {
            const btn = this;
            btn.disabled = true;
            btn.innerHTML = `<span class="spinner-border spinner-border-sm me-1"></span> Saving...`;
            Loader.show();
            try {
                // ── Step 1: Validate basic fields ──
                const name = document.getElementById("name").value.trim();
                const model = document.getElementById("model").value.trim();
                const color = document.getElementById("color").value.trim();
                const brand_id = parseInt(document.getElementById("brand_id").value) || null;
                const category_id = parseInt(document.getElementById("category_id").value) || null;
                const fuel_type_id = parseInt(document.getElementById("fuel_type_id").value) || null;
                const transmission = document.getElementById("transmission").value || null;
                const seating_capacity = parseInt(document.getElementById("seating_capacity").value) || null;

                if (!name || !model || !color || !brand_id || !category_id || !fuel_type_id || !transmission || !seating_capacity) {
                    showAlert("Please fill all required fields: Name, Model, Color, Brand, Category, Fuel Type, Transmission, and Seating Capacity.");
                    btn.disabled = false;
                    btn.innerHTML = `<i class="bi bi-check-circle me-1"></i> Save Changes`;
                    return;
                }

                // ── Step 2: Validate pricing rows ──
                const pricings = getPricingData();

                if (pricings.length === 0) {
                    showAlert("Please add at least one Pricing Tier.");
                    btn.disabled = false;
                    btn.innerHTML = `<i class="bi bi-check-circle me-1"></i> Save Changes`;
                    return;
                }

                for (let i = 0; i < pricings.length; i++) {
                    const p = pricings[i];
                    if (!p.base_price || !p.duration_hours || !p.included_km || !p.extra_hour_charge || !p.extra_km_charge) {
                        showAlert(`Please fill all required fields in Pricing Tier #${i + 1}.`);
                        btn.disabled = false;
                        btn.innerHTML = `<i class="bi bi-check-circle me-1"></i> Save Changes`;
                        return;
                    }
                }

                // ── Step 3: Submit car update ──
                const carPayload = {
                    name, model, color, brand_id, category_id, fuel_type_id,
                    transmission, seating_capacity,
                    is_active: document.getElementById("is_active").checked,
                    is_premium: document.getElementById("is_premium").checked,
                    order_by: parseInt(document.getElementById("order_by").value) || 0,
                    pricings,
                };

                const carRes = await fetch(`/admin/update/cars/${CAR_ID}`, {
                    method: "PUT",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(carPayload),
                });
                const carData = await carRes.json();

                if (!carRes.ok) {
                    showAlert(carData.message || "Failed to update car.");
                    btn.disabled = false;
                    btn.innerHTML = `<i class="bi bi-check-circle me-1"></i> Save Changes`;
                    return;
                }

                // ── Step 4: Upload new images if any ──
                const validFiles = selectedFiles.filter(f => f !== null);
                if (validFiles.length > 0) {
                    const formData = new FormData();
                    validFiles.forEach((entry, i) => {
                        formData.append("images", entry.file);
                        formData.append(`is_primary_${i}`, entry.is_primary ? "true" : "false");
                        formData.append(`with_bg_${i}`, entry.with_bg ? "true" : "false");
                    });

                    const imgRes = await fetch(`/admin/car/${CAR_ID}/images`, {
                        method: "POST",
                        body: formData,
                    });

                    if (!imgRes.ok) {
                        const imgData = await imgRes.json();
                        showAlert(`Car updated, but new image upload failed: ${imgData.message || "Unknown error"}`, "warning");
                        btn.disabled = false;
                        btn.innerHTML = `<i class="bi bi-check-circle me-1"></i> Save Changes`;
                        return;
                    }
                }

                showAlert("Car updated successfully! Redirecting...", "success");
                setTimeout(() => { window.location.href = "/admin/cars"; }, 1500);

            } catch (err) {
                console.error(err);
                showAlert("An unexpected error occurred. Please try again.");
                btn.disabled = false;
                btn.innerHTML = `<i class="bi bi-check-circle me-1"></i> Save Changes`;
            }
            finally{
                Loader.hide();
            }
        });

    })();
</script>