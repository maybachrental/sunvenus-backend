<script>
    document.addEventListener("DOMContentLoaded", function () {

        const currentPath = window.location.pathname;

        const links = document.querySelectorAll("#navigation .nav-link");

        let activeLink = null;
        let longestMatch = 0;

        links.forEach(link => {

            const href = link.getAttribute("href");

            if (!href || href === "#") return;

            // find best matching route
            if (currentPath.startsWith(href) && href.length > longestMatch) {
                longestMatch = href.length;
                activeLink = link;
            }

        });

        if (activeLink) {

            activeLink.classList.add("active");

            let parent = activeLink.closest(".nav-item");

            while (parent) {

                const treeview = parent.querySelector(":scope > .nav-treeview");

                if (treeview) {
                    parent.classList.add("menu-open");
                }

                parent = parent.parentElement.closest(".nav-item");
            }
        }

    });
</script>